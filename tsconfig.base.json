{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@cherrytree/shared": ["./packages/shared/src"],
      "@cherrytree/server": ["./packages/server/src"],
      "@cherrytree/client": ["./packages/client/src"],
      "@cherrytree/cli": ["./packages/cli/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
